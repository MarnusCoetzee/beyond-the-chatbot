{
  "name": "agent-backend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["agent-backend"],
  "projectType": "application",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "e2e/agent-backend-e2e/jest.config.cjs",
        "passWithNoTests": true
      },
      "dependsOn": ["agent-backend:build", "agent-backend:serve"]
    }
  }
}
